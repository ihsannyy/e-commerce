# Admin Dashboard Authentication Settings
# Set a secure password for the admin panel (defaults to admin123 if not set)
ADMIN_PASSWORD=admin123

# Telegram Notification Bot Settings
# Obtain these credentials from @BotFather and @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
